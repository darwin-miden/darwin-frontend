# Flow B trigger note -- browser-SDK-compatible. Zero-asset note that
# calls into the v4 controller's execute_rebalance_step.

use miden::core::sys

const BASKET_ID = 1
const REBALANCE_TS = 1747500000

@note_script
pub proc main
    push.REBALANCE_TS
    push.BASKET_ID
    call.0xddff122fa9aff9c1e5b5c253b509d24a795a9ad709f32d54e91eb53a77b84c53
    exec.sys::truncate_stack
end
