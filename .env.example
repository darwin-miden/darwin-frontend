# darwin-frontend — environment variables.
#
# Copy to .env.local for dev (already in .gitignore) or paste into the
# Vercel project settings for production. Only NEXT_PUBLIC_* vars are
# exposed to the browser; everything else stays server-side.

# --- backend URLs ---------------------------------------------------

# darwin-relay v2 REST. Defaults to http://localhost:8090 (local dev).
# For a production deployment (Fly.io, Hetzner, etc.) replace with the
# reachable HTTPS URL of your relay. The frontend's BaliWithdrawPanel
# + Bali bridge flows call this directly from the browser; CORS is
# permissive on the relay so the same-origin requirement is just
# "the URL must be reachable from the visitor's browser".
#
# Do NOT ship a speculative DNS name (e.g. https://relay.darwin.xyz
# before that domain resolves) — every redeem/deposit POST then fails
# silently (CORS-blocked unresolvable host) and the UI shows no error
# to the visitor.
NEXT_PUBLIC_RELAY_V2_URL=http://localhost:8090

# NEAR Intents 1Click mock (Brian's miden-testnet-bridge — testnet
# placeholder; replaced by real NEAR Intents API once Miden is a
# supported chain). Bring up locally via `make sepolia` in
# miden-testnet-bridge. Same caveat as RELAY_V2_URL above re:
# unresolvable hostnames.
NEXT_PUBLIC_ONECLICK_URL=http://localhost:8080

# --- chain RPCs (browser-side) -------------------------------------

# Sepolia RPC. publicnode is CORS-friendly and free. For prod-grade
# SLA switch to Alchemy/QuickNode.
NEXT_PUBLIC_SEPOLIA_RPC_HTTP=https://ethereum-sepolia-rpc.publicnode.com

# Mainnet RPC. Only used by ConnectKit for ENS resolution — never
# touched for protocol writes.
NEXT_PUBLIC_MAINNET_RPC_HTTP=https://ethereum-rpc.publicnode.com

# --- wallet ---------------------------------------------------------

# WalletConnect Cloud project id from https://cloud.reown.com.
# Leave UNSET (or set to "darwin-protocol-demo") to disable WC and
# force MetaMask injected only. A bogus id makes WC retry forever
# and spam the console; the wagmi config treats the placeholder as
# "no WC" exactly to avoid that footgun.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# --- feature flags --------------------------------------------------

# Set to "1" to hide the MidenFi (custodial) flow and surface only
# the self-custody panel for Miden-native users. Defaults to off.
NEXT_PUBLIC_MIDEN_SELF_CUSTODY=

# Epoch protocol allocator URL — hosted Sepolia → Miden bridge.
# Default points at Miden team's testnet-dev deployment. Set this if
# you want to swap in a self-hosted allocator for the EpochDepositPanel.
NEXT_PUBLIC_ALLOCATOR_URL=https://testnet-dev.epochprotocol.xyz

# Server-side testnet USDC faucet (/api/faucet-usdc). A DISPOSABLE signer key
# that pays gas to mint the public mock USDC to new accounts, so a first-time
# tester with no Sepolia ETH still gets funded (invisible auto-mint + the
# "Get test USDC" button). Generate a throwaway key (`cast wallet new`), fund it
# with a little Sepolia ETH, and set it here. NEVER put a real/dev key here.
FAUCET_PK=
# Sepolia RPC used by the faucet route (falls back to publicnode if unset).
SEPOLIA_RPC_HTTP=https://ethereum-sepolia-rpc.publicnode.com
